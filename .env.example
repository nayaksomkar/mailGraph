# ============================================
# MailGraph Environment Configuration
# ============================================
# Copy this file to .env and fill in your values
# ============================================

# ============================================
# LLM PROVIDER SETTINGS (REQUIRED)
# ============================================
# Choose ONE provider: groq or mistral
LLM_PROVIDER=groq

# GROQ: Get free key at https://console.groq.com/keys
# Example: gsk_xxxxxxxxxxxxxxxxxxxx
GROQ_API_KEY=

# MISTRAL: Get key at https://console.mistral.ai/api-keys
# Example: xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
MISTRAL_API_KEY=

# Model to use (depends on provider):
# Groq models: llama-3.1-8b-instant, llama-3.1-70b-versatile, mixtral-8x7b-32768, gemma-7b-it
# Mistral models: mistral-small-latest, mistral-medium-latest, mistral-large-latest
LLM_MODEL=llama-3.1-8b-instant

# Temperature: 0.0 = deterministic, 1.0 = creative
LLM_TEMPERATURE=0.7

# LangGraph: Max refinement iterations (1-5)
MAX_ITERATIONS=3

# LangGraph: Quality threshold (1-10). Higher = stricter quality
CRITIQUE_THRESHOLD=8

# ============================================
# GMAIL API SETTINGS (REQUIRED)
# ============================================
# Get from Google Cloud Console: https://console.cloud.google.com/
# 1. Create project -> Enable Gmail API
# 2. APIs & Services -> Credentials -> Create OAuth 2.0 Client ID
# 3. Type: Web application
# 4. Add redirect URI: http://localhost:3000/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ============================================
# DATABASE SETTINGS
# ============================================
# MongoDB connection (default works for local/Docker)
MONGODB_URI=mongodb://localhost:27017/mailgraph

# Docker MongoDB credentials (if using docker-compose)
MONGO_USERNAME=admin
MONGO_PASSWORD=password

# ============================================
# SERVER SETTINGS
# ============================================
# Python FastAPI port
PYTHON_PORT=8000

# Node.js Gmail proxy port
NODE_PORT=3000

# Environment
NODE_ENV=development
DEBUG=true
LOG_LEVEL=info

# ============================================
# SECURITY (REQUIRED - change these!)
# ============================================
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=change-me-to-random-string
SESSION_SECRET=change-me-to-random-string